# ====================================================================
# STAGING ENVIRONMENT CONFIGURATION
# ====================================================================
# This file is used for staging/testing deployments.
# It connects to the staging backend and should mirror production behavior.
#
# Used for:
#   - Pre-release testing
#   - QA verification
#   - Integration testing with staging services
# ====================================================================

# API Base URL — staging backend
# Replace with your actual staging backend domain
API_BASE_URL=https://staging-api.synaptixplay.com

# API Health Check endpoint
API_HEALTH_PATH=/healthz

# WebSocket Base URL
API_WS_BASE_URL=wss://staging-api.synaptixplay.com/ws

# Match hub for multiplayer game state
API_MATCH_HUB_URL=wss://staging-api.synaptixplay.com/ws/match

# Presence hub for online status tracking
API_PRESENCE_HUB_URL=wss://staging-api.synaptixplay.com/ws/presence

# Notification hub for real-time alerts
API_NOTIFY_HUB_URL=wss://staging-api.synaptixplay.com/ws/notify

# App redirect base URL for payment/OAuth flows
APP_REDIRECT_BASE_URL=https://staging-app.synaptixplay.com

# Compliance microservice for staging
COMPLIANCE_SERVICE_URL=https://staging-compliance.synaptixplay.com

# Stripe Identity (KYC) — use test publishable key for staging
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# gRPC Configuration for backend MobileMatchService
GRPC_HOST=staging-api.synaptixplay.com
GRPC_PORT=5001
GRPC_USE_TLS=true

# Enable crypto surfaces for staging testing
CRYPTO_SURFACES_ENABLED=true
CRYPTO_WRITES_ENABLED=true
CRYPTO_ENABLED_NETWORKS=solana,xrp

# External authentication providers (enable for staging testing if configured)
EXTERNAL_AUTH_PROVIDERS_ENABLED=false

# Timeout settings
API_CONNECT_TIMEOUT_SECONDS=10
API_RECEIVE_TIMEOUT_SECONDS=30
API_SEND_TIMEOUT_SECONDS=10
API_REFRESH_RECEIVE_TIMEOUT_SECONDS=20

# Backend logging (ASP.NET Core)
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGLEVEL__MICROSOFT__ASPNETCORE=Warning

# Enable client-side logging
ENABLE_LOGGING=true
