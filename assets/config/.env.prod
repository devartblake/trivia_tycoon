# ====================================================================
# PRODUCTION / ALPHA / BETA RELEASE CONFIGURATION
# ====================================================================
# This file is used for alpha/beta releases and production deployments.
# It connects to the actual backend API instead of local development servers.
#
# IMPORTANT: This file should NOT include sensitive secrets in version control.
# Secrets (API keys, signing keys, etc.) should be injected at build/deploy time.
# ====================================================================

# API Base URL — connects to the actual web backend
# Replace with your actual backend domain
API_BASE_URL=https://api.synaptixplay.com

# API Health Check endpoint
API_HEALTH_PATH=/healthz

# WebSocket Base URL
# Automatically converted from https to wss by EnvConfig if not specified
API_WS_BASE_URL=wss://api.synaptixplay.com/ws

# Match hub for multiplayer game state
API_MATCH_HUB_URL=wss://api.synaptixplay.com/ws/match

# Presence hub for online status tracking
API_PRESENCE_HUB_URL=wss://api.synaptixplay.com/ws/presence

# Notification hub for real-time alerts
API_NOTIFY_HUB_URL=wss://api.synaptixplay.com/ws/notify

# App redirect base URL for payment/OAuth flows
APP_REDIRECT_BASE_URL=https://app.synaptixplay.com

# Compliance microservice (US regulatory: COPPA/CCPA/KYC/AML/geo-block)
# Set to empty/blank if not deployed; crypto and prize gates will be disabled
COMPLIANCE_SERVICE_URL=https://compliance.synaptixplay.com

# Stripe Identity (KYC) — publishable key only; secret key lives in the compliance service
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# gRPC Configuration for backend MobileMatchService
# TLS is REQUIRED for production; gRPC host defaults to API_BASE_URL host
GRPC_HOST=api.synaptixplay.com
GRPC_PORT=5001
GRPC_USE_TLS=true

# Enable/Disable crypto surfaces (wallet, staking, withdrawals)
CRYPTO_SURFACES_ENABLED=true
CRYPTO_WRITES_ENABLED=true
CRYPTO_ENABLED_NETWORKS=solana,xrp

# External authentication providers (OAuth, Game Center, Play Games)
# Keep disabled (false) until server-side provider credentials are configured
EXTERNAL_AUTH_PROVIDERS_ENABLED=false

# Timeout settings for API communication (in seconds)
API_CONNECT_TIMEOUT_SECONDS=10
API_RECEIVE_TIMEOUT_SECONDS=30
API_SEND_TIMEOUT_SECONDS=10
API_REFRESH_RECEIVE_TIMEOUT_SECONDS=20

# Backend logging (ASP.NET Core) — reduce noisy request lifecycle logs
LOGGING__LOGLEVEL__DEFAULT=Warning
LOGGING__LOGLEVEL__MICROSOFT__ASPNETCORE=Warning

# Enable client-side logging
ENABLE_LOGGING=true
