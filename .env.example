# ====================================================================
# DEBUG BUILD CONFIGURATION (used during development)
# ====================================================================
# For production/alpha/beta releases: Use .env.prod
# For staging testing: Use .env.staging
# For local Docker testing: Use .env.local
#
# This mirrors the Flutter client-safe subset of TycoonTycoon_Backend/docker
# env files. Do not copy backend secrets such as JWT/database/KMS/admin
# credentials into Flutter env files; they can be packaged with the app.
# Platform-aware host rewriting is handled automatically by EnvConfig.
# ====================================================================

API_BASE_URL=http://10.0.2.2:5000
API_HEALTH_PATH=/healthz
API_WS_BASE_URL=ws://10.0.2.2:5000/ws
API_MATCH_HUB_URL=ws://10.0.2.2:5000/ws/match
API_PRESENCE_HUB_URL=ws://10.0.2.2:5000/ws/presence
API_NOTIFY_HUB_URL=ws://10.0.2.2:5000/ws/notify
APP_REDIRECT_BASE_URL=http://localhost:3000
COMPLIANCE_SERVICE_URL=http://10.0.2.2:5070
COMPLIANCE_CONSENT_SERVICE_URL=
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

GRPC_HOST=10.0.2.2
GRPC_PORT=5001
GRPC_USE_TLS=false

CRYPTO_SURFACES_ENABLED=true
CRYPTO_WRITES_ENABLED=true
CRYPTO_ENABLED_NETWORKS=solana,xrp
EXTERNAL_AUTH_PROVIDERS_ENABLED=false

API_CONNECT_TIMEOUT_SECONDS=10
API_RECEIVE_TIMEOUT_SECONDS=30
API_SEND_TIMEOUT_SECONDS=10
API_REFRESH_RECEIVE_TIMEOUT_SECONDS=20

LOGGING__LOGLEVEL__DEFAULT=Debug
LOGGING__LOGLEVEL__MICROSOFT__ASPNETCORE=Debug
ENABLE_LOGGING=true

# --- Sentry Error Tracking ---
# Sentry DSN for centralized error tracking and performance monitoring
# Development: Full trace sampling for debugging
# For production: Get real DSN from https://sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=1.0
