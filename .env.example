=
API_BASE_URL=http://10.0.2.2:5000
API_HEALTH_PATH=/healthz
API_WS_BASE_URL=http://10.0.2.2:5000/ws
APP_REDIRECT_BASE_URL=https://app.synaptixplay.com
COMPLIANCE_SERVICE_URL=http://localhost:5002
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
=
GRPC_HOST=
GRPC_PORT=
GRPC_USE_TLS=
=
CRYPTO_SURFACES_ENABLED=
CRYPTO_WRITES_ENABLED=
CRYPTO_ENABLED_NETWORKS=
EXTERNAL_AUTH_PROVIDERS_ENABLED=
=
API_CONNECT_TIMEOUT_SECONDS=10
API_RECEIVE_TIMEOUT_SECONDS=30
API_SEND_TIMEOUT_SECONDS=10
API_REFRESH_RECEIVE_TIMEOUT_SECONDS=20
=
LOGGING__LOGLEVEL__DEFAULT=Warning
LOGGING__LOGLEVEL__MICROSOFT__ASPNETCORE=Warning
ENABLE_LOGGING=true

# --- Sentry Error Tracking ---
# Sentry DSN for centralized error tracking and performance monitoring
# Development: Full trace sampling for debugging
# For production: Get real DSN from https://sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACE_SAMPLE_RATE=
