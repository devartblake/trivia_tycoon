# API Base URLs for Different Environments
API_BASE_URL=https://localhost:5000
API_BASE_URL_DEV=
API_BASE_URL_STAGING=
API_BASE_URL_PROD=

# Optional explicit WebSocket base URL. If omitted, app derives this from API_BASE_URL
# by converting http(s) -> ws(s).
API_WS_BASE_URL=ws://localhost:5000

# Optional explicit WebSocket hubs. If omitted, app derives:
# API_MATCH_HUB_URL=${API_WS_BASE_URL}/ws/match
# API_PRESENCE_HUB_URL=${API_WS_BASE_URL}/ws/presence
# API_NOTIFY_HUB_URL=${API_WS_BASE_URL}/ws/notify
API_MATCH_HUB_URL=
API_PRESENCE_HUB_URL=
API_NOTIFY_HUB_URL=

# Client logging (Flutter)
ENABLE_LOGGING=false

# Backend logging (ASP.NET Core) - reduce noisy request lifecycle logs
# Keeps warnings/errors while suppressing per-request info entries such as
# "Request starting", "Executing endpoint", and "Request finished".
Logging__LogLevel__Default=Warning
Logging__LogLevel__Microsoft.AspNetCore=Warning
ENABLE_LOGGING=true
